{
  "name": "markdown-magpie",
  "private": true,
  "version": "0.1.0",
  "description": "Git-backed Markdown knowledge base maintenance with cited answers, gap detection, and pull request proposals.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @magpie/core && npm run build -w @magpie/logger && npm run build -w @magpie/prompts && npm run build -w @magpie/markdown && npm run build -w @magpie/retrieval && npm run build -w @magpie/git && npm run build -w @magpie/jobs && npm run build -w @magpie/auth && npm run build -w @magpie/telemetry && npm run build -w @magpie/api && npm run build -w @magpie/watcher && npm run build -w @magpie/mcp && npm run build -w @magpie/web",
    "build:libs": "tsc -b tsconfig.libs.json",
    "db:migrate": "node scripts/migrate.mjs",
    "deadcode": "knip",
    "predev:api": "npm run build:libs",
    "dev:api": "node --watch --env-file=.env --import tsx apps/api/src/main.ts",
    "predev:watcher": "npm run build:libs",
    "dev:watcher": "node --env-file=.env --import tsx apps/watcher/src/main.ts",
    "dev:web": "npm run dev -w @magpie/web",
    "dev": "npm run dev --workspaces --if-present",
    "eval:api": "node --import tsx scripts/eval-api.ts",
    "eval:gap-threshold": "node --import tsx scripts/eval-gap-threshold.ts",
    "preeval:golden": "npm run build:libs",
    "eval:golden": "node scripts/test-db.mjs node --import tsx scripts/eval-golden.ts",
    "e2e:jobs": "node --import tsx scripts/e2e-jobs.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspaces --if-present",
    "test:scripts": "node --test \"scripts/**/*.test.mjs\"",
    "test:timings": "node scripts/test-timings.mjs",
    "test:slow": "node scripts/test-timings.mjs --verify",
    "test:db": "node scripts/test-db.mjs npm run test",
    "test:integration": "RUN_PG_INTEGRATION=1 node --import tsx --test apps/api/src/jobs/pg-boss-broker.integration.test.ts",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:db:coverage": "node scripts/test-db.mjs npm run test:coverage",
    "typecheck": "tsc -p tsconfig.check.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testcontainers/postgresql": "^12.0.4",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "knip": "^6.25.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=22.13"
  }
}
