DATABASE_URL=postgres://postgres:postgres@localhost:5432/markdown_magpie
QUEUE_URL=redis://localhost:6379
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# Provider-neutral defaults. Set provider-specific values only for enabled adapters.
LLM_PROVIDER=mock
CHAT_PROVIDER=mock
EMBEDDING_PROVIDER=mock
GIT_PROVIDER=local
KNOWLEDGE_REPO_PATH=../markdown-magpie-kb
KNOWLEDGE_STORE=memory
AI_EXECUTION_MODE=direct
AI_JOB_QUEUE=memory
AI_JOB_PROVIDER=mock
WATCHER_NAME=local-dev-watcher
WATCHER_POLL_INTERVAL_MS=2000

# Azure-compatible optional settings
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# OpenAI-compatible optional settings
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# Git provider optional settings
GITHUB_TOKEN=
AZURE_DEVOPS_ORG_URL=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=

# External agent watcher optional settings
CODEX_CLI_PATH=codex
CLAUDE_CLI_PATH=claude
