DATABASE_URL=postgres://postgres:postgres@localhost:5432/markdown_magpie
QUEUE_URL=redis://localhost:6379
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# Provider-neutral defaults. Set provider-specific values only for enabled adapters.
AI_EXECUTION_MODE=direct
AI_PROVIDER=mock
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock
GIT_PROVIDER=local
# Read sources for raw material. Entries may be local paths, git URLs, internet hints, or agent knowledge.
KNOWLEDGE_SOURCES=[{"id":"cats","name":"Cats Source","path":"knowledge-bases/cats"}]
# Write destinations for generated Markdown proposals. Use subpath for a docs folder inside a repo.
KNOWLEDGE_DESTINATIONS=[{"id":"cats","name":"Cats Docs","path":"knowledge-bases/cats"}]
# Knowledge flows link raw sources to the curated destination KB used by /ask and MCP.
KNOWLEDGE_FLOWS=[{"id":"cats","name":"Cats KB","sourceIds":["cats"],"destinationId":"cats"}]
# Managed clone root for git sources and destinations. Git endpoints sync here at API startup.
MAGPIE_CHECKOUT_ROOT=.magpie/checkouts
# Backward-compatible repository config. Used only when KNOWLEDGE_SOURCES/KNOWLEDGE_DESTINATIONS are unset.
KNOWLEDGE_REPOSITORIES=
# Legacy single-repository fallback when KNOWLEDGE_REPOSITORIES is unset.
KNOWLEDGE_REPO_PATH=
STORAGE_BACKEND=postgres
WATCHER_NAME=local-dev-watcher
WATCHER_POLL_INTERVAL_MS=2000
AGENT_API_TIMEOUT_MS=120000

# Azure-compatible optional settings
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# OpenAI-compatible chat (question answering) settings
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# OpenAI-compatible embedding settings (hybrid retrieval).
# Set KNOWLEDGE_STORE=postgres and an embedding model to enable semantic search.
# Base URL and API key default to the chat values above when left blank, so you
# only set these when embeddings live on a different endpoint than chat
# (e.g. DeepSeek for chat, OpenAI for embeddings). Model must be 1536-dim.
OPENAI_COMPATIBLE_EMBEDDING_BASE_URL=
OPENAI_COMPATIBLE_EMBEDDING_API_KEY=
OPENAI_COMPATIBLE_EMBEDDING_MODEL=

# Git provider optional settings
GITHUB_TOKEN=
AZURE_DEVOPS_ORG_URL=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=

# External agent watcher optional settings
CODEX_CLI_PATH=codex
CODEX_CLI_ARGS=exec
CODEX_CLI_PROMPT_MODE=arg
CLAUDE_CLI_PATH=claude
CLAUDE_CLI_ARGS=-p
CLAUDE_CLI_PROMPT_MODE=arg
AGENT_CLI_TIMEOUT_MS=120000
