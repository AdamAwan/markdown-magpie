# markdown-magpie — local development template.
# Copy to .env and adjust. Used when running the apps directly (npm run dev:*),
# with Postgres reachable on localhost.
# .env is gitignored — never commit real keys.

# ── Core services ────────────────────────────────────────────────
# Postgres connection. REQUIRED. Postgres backs every store and the pg-boss job
# queue that all AI work runs through, so the API and watcher fail to start
# without it.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/markdown_magpie

# Shared Postgres connection pool tuning for the API. Every store shares ONE pool
# (pg-boss keeps its own separate pool), so DB_POOL_MAX is the per-API-instance
# connection ceiling for application queries. Defaults shown; all optional.
# DB_POOL_MAX=10                 # max connections in the shared store pool
# DB_IDLE_TIMEOUT_MS=30000       # close a connection after it is idle this long
# DB_CONNECTION_TIMEOUT_MS=10000 # fail if a connection can't be acquired in time
# DB_STATEMENT_TIMEOUT_MS=30000  # server-side cap so a hung query can't pin a conn

# Browser-facing API URL for the Next.js web app.
#   NEXT_PUBLIC_API_BASE_URL is inlined at BUILD time (read by client code).
#   PUBLIC_API_BASE_URL is read at runtime by the server layout as a fallback.
# Leave both blank when the API is served from the same origin as the web app.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
PUBLIC_API_BASE_URL=

# Base URL the watcher, MCP server, and eval script use to reach the API.
# (The web app does NOT use this — it uses the *_PUBLIC_* vars above.)
API_BASE_URL=http://localhost:4000

# CORS allow-list for the API's Access-Control-Allow-Origin header. Unset or "*"
# (the default) allows any origin. In production set it to a comma-separated list
# of the web origin(s) allowed to call the API, e.g.
#   CORS_ALLOWED_ORIGINS=https://magpie.example.com
# CORS_ALLOWED_ORIGINS=*

# ── Auth0 (FAILS CLOSED — required unless explicitly disabled) ────
# AUTH_REQUIRED gates token validation across the API and both MCP transports.
# It FAILS CLOSED: auth is REQUIRED by default and is only disabled when this is
# set EXACTLY to false. An unset, blank, or typo'd value leaves auth ON, so a
# misconfiguration can never silently expose the API. When auth is required the
# API refuses to start unless AUTH0_AUDIENCE (a real identifier, not the
# placeholder below) and AUTH0_DOMAIN/AUTH0_ISSUER_BASE_URL are set.
# For unauthenticated local development, opt out explicitly:
AUTH_REQUIRED=false
# Auth0 tenant for token validation. Set AUTH0_ISSUER_BASE_URL to the full issuer
# (e.g. https://your-tenant.eu.auth0.com), or set AUTH0_DOMAIN and the issuer is
# derived as https://<domain>/. Either works; the issuer base takes precedence.
# REQUIRED when AUTH_REQUIRED is not false.
AUTH0_DOMAIN=
AUTH0_ISSUER_BASE_URL=
# API identifier (audience) the tokens must carry. Must match the Auth0 API.
# The value below is a PLACEHOLDER: booting with auth enabled and this value is
# rejected. Replace it with your real Auth0 API identifier before enabling auth.
AUTH0_AUDIENCE=https://markdown-magpie.local/api
# Optional override for the JWKS endpoint. Defaults to
# https://<domain>/.well-known/jwks.json when unset (the issuer is
# normalised to carry a trailing slash before the path is appended).
# AUTH0_JWKS_URI=
#
# Flow-scoped authorization (optional; see docs/authorization.md).
# AUTH_ROLES_CLAIM is the JWT claim key an Auth0 post-login Action stamps with the
# user's role names (a namespaced custom claim). Defaults to the value below.
# AUTH_ROLES_CLAIM=https://magpie.wastedcake.com/roles
# KNOWLEDGE_ROLE_GRANTS maps role name -> flow id (or "*") -> capabilities
# (read|manage|ask|admin). Leaving it UNSET keeps flow-scoping inactive (the API
# behaves exactly as the global-scope-only model). Configuring it activates
# per-flow checks on proposals, gaps, ask, and the destructive /admin/reset.
# KNOWLEDGE_ROLE_GRANTS={"kb-hr-curators":{"hr":["read","manage"]},"kb-askers-all":{"*":["ask"]},"kb-super":{"*":["read","manage","ask","admin"]}}
# Web app (Next.js) Auth0 SPA settings.
#
# For a DISTRIBUTABLE image, set the non-prefixed vars below. They are read at
# request time by the web server (layout.tsx renders force-dynamic) and injected
# into window.__MAGPIE_CONFIG__, so one prebuilt image can be configured per
# deployment with no rebuild. AUTH0_DOMAIN and AUTH0_AUDIENCE above are reused.
AUTH0_CLIENT_ID=
AUTH0_REDIRECT_URI=http://localhost:3000
#
# The NEXT_PUBLIC_* equivalents are OPTIONAL build-time overrides: when set
# during `next build` they are inlined into the bundle and take precedence over
# the runtime vars. Leave blank to keep the image generic and configure at
# runtime via the AUTH0_* vars above.
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=
NEXT_PUBLIC_AUTH0_REDIRECT_URI=
# Public URL of the HTTP MCP endpoint (used in the OAuth protected-resource
# metadata). Match the externally reachable /mcp URL.
MCP_RESOURCE_URL=http://localhost:4001/mcp
# Endpoint the web "Connect over MCP" panel shows to users. Read at runtime from
# window.__MAGPIE_CONFIG__ (falls back to MCP_RESOURCE_URL, then localhost). The
# NEXT_PUBLIC_ form is an optional build-time inline override.
NEXT_PUBLIC_MCP_URL=
# Audience the HTTP MCP server validates inbound user tokens against. This is the
# MCP server's OWN Auth0 API identifier and is SEPARATE from AUTH0_AUDIENCE (the
# web API). MCP clients request tokens via the RFC 8707 `resource` parameter, so
# Auth0 stamps aud = the /mcp URL; the server must validate that, not the web
# API audience. Defaults to MCP_RESOURCE_URL — only set this if the Auth0 API
# identifier differs from the public /mcp URL.
# MCP_AUDIENCE=
# Bearer token the stdio MCP transport presents to the API. Required when
# AUTH_REQUIRED=true (stdio MCP fails fast at startup otherwise).
MCP_AUTH_TOKEN=
# Downstream API service credential for the HTTP MCP transport (its own
# machine-to-machine identity; user tokens are validated locally and never
# forwarded). Provide ONE of the following when AUTH_REQUIRED=true (HTTP MCP
# fails fast at startup otherwise):
#
#   PREFERRED — client-credentials, fetched and refreshed at runtime so it
#   survives the ~24h Auth0 token lifetime. The token is requested from
#   <issuer>/oauth/token for the AUTH0_AUDIENCE (web API) audience.
MCP_API_CLIENT_ID=
MCP_API_CLIENT_SECRET=
#
#   LEGACY — a static pre-minted access token. Simpler but EXPIRES (Auth0 default
#   24h); after expiry every tools/call fails until the token is replaced. Use
#   the client-credentials pair above instead for any long-running deployment.
MCP_API_AUTH_TOKEN=

# ── Storage backends (memory | postgres) ────────────────────────
# STORAGE_BACKEND is the default for every store.
STORAGE_BACKEND=postgres
# KNOWLEDGE_STORE must be "postgres" to enable semantic/hybrid retrieval
# (pgvector). Defaults to STORAGE_BACKEND when unset, as do the overrides below.
KNOWLEDGE_STORE=postgres
# QUESTION_LOG_STORE=
# PROPOSAL_STORE=

# ── AI provider selection ────────────────────────────────────────
# All AI work runs on the queue: a watcher process completes AI jobs. The API
# never runs AI inline. AI_PROVIDER is mandatory and must name a watcher
# provider — startup fails if it is unset or unsupported.
# Valid: openai-compatible | azure-openai | codex | claude.
# The watcher must be configured with the matching provider's credentials.
# The embedding provider used for retrieval is auto-detected from its env vars;
# with no embedding provider configured, retrieval is keyword-only.
AI_PROVIDER=openai-compatible

# -- Knowledge configuration ------------------------------------------------
# Configure your own Markdown knowledge sources and destinations. Leave these
# empty until you have a local folder or git repository to index.
# Example local setup:
#   KNOWLEDGE_SOURCES=[{"id":"docs","name":"Product Docs","path":"knowledge-bases/product"}]
#   KNOWLEDGE_DESTINATIONS=[{"id":"docs","name":"Product Docs","path":"knowledge-bases/product"}]
#   KNOWLEDGE_FLOWS=[{"id":"docs","name":"Product Docs","sourceIds":["docs"],"destinationId":"docs"}]
KNOWLEDGE_SOURCES=[]
KNOWLEDGE_DESTINATIONS=[]
KNOWLEDGE_FLOWS=[]
# Managed clone root for git-backed sources/destinations (synced at API startup).
MAGPIE_CHECKOUT_ROOT=.magpie/checkouts
# Where the API writes per-flow snapshots (gaps/proposals/PR state read back by the
# reconciler and /snapshots page). Like MAGPIE_CHECKOUT_ROOT, a relative default
# resolves under the process working directory — in a container that is the
# read-only /app, so point this at a writable, mounted path in deployments.
MAGPIE_SNAPSHOT_ROOT=.magpie/snapshots
# Legacy fallbacks, used only when KNOWLEDGE_SOURCES/DESTINATIONS are unset.
# KNOWLEDGE_REPOSITORIES=
# KNOWLEDGE_REPO_PATH=

# -- Job queue (API side) ─────────────────────────────────────────
# All AI work runs through the pg-boss job queue in Postgres. Clients
# POST a job, receive 202, then block on GET /api/jobs/:id/wait (200 once
# terminal, otherwise 202 — keep polling). These tune that flow.
# JOB_WAIT_TIMEOUT_MS bounds how long a single /wait call blocks before
# returning 202 so the client can re-issue it. JOB_WAIT_POLL_MS is the
# server-side poll cadence while a /wait call is in flight.
JOB_WAIT_TIMEOUT_MS=25000
JOB_WAIT_POLL_MS=250
# Timezone applied to scheduled (cron) jobs registered with pg-boss.
JOB_SCHEDULE_TIMEZONE=UTC

# ── Rate limiting & AI cost controls ─────────────────────────────
# Per-principal request throttling plus a global cap on concurrent metered AI
# work. On by default; set RATE_LIMIT_ENABLED=false to disable both. The
# per-principal limiter keys on the authenticated subject, so it is inert when
# auth is disabled (there is no principal to attribute requests to). See
# docs/rate-limiting.md for the log-event schema and Grafana queries.
# RATE_LIMIT_ENABLED=false          # kill switch for L1 + L2 (default: enabled)
RATE_LIMIT_WINDOW_MS=60000          # fixed-window width shared by both tiers
RATE_LIMIT_ASK_PER_WINDOW=30        # /ask + /retrieve, per principal per window
RATE_LIMIT_TRIGGER_PER_WINDOW=5     # manual run/index triggers, per principal
# Global ceiling on in-flight (created|retry|active) AI jobs; /ask returns 429
# once this many are already running (admission control, not a queue-and-wait).
AI_MAX_INFLIGHT_JOBS=20

# ── Flow router (embedding-first, chat fallback) ─────────────────
# Abstain-biased cosine cut-offs for POST /api/route, which picks a flow by
# embedding similarity before falling back to a chat completion. The top flow must
# clear MIN_SCORE and beat the runner-up by MIN_MARGIN, else the router abstains and
# the watcher uses the chat router. A mis-tune only costs savings, never routing
# correctness (abstaining reproduces the pre-embedding behaviour). Both are floats in
# [0,1]; blank/out-of-range falls back to the defaults shown.
FLOW_ROUTER_MIN_SCORE=0.25
FLOW_ROUTER_MIN_MARGIN=0.05

# ── Watcher (polls the API and completes AI jobs) ────────────────
# A watcher advertises a capability only when its required env vars are set
# (see the provider sections below). The API never runs AI inline — without a
# matching watcher running, jobs stay queued.
WATCHER_NAME=local-dev-watcher
# How often the watcher polls the API for a claimable job.
WATCHER_POLL_INTERVAL_MS=2000
# Abort deadline for the maintenance orchestration callbacks (reconcile-gaps,
# source-sync, fix-patrol, improve-patrol). These API endpoints bounded-wait on a
# batch of AI jobs and legitimately run for minutes, so they get a far longer
# deadline than the hot-path request timeout. Default 15 min; raise toward the
# maintenance job's 1-hour budget for very large patrol batches. Optional.
# WATCHER_MAINTENANCE_TIMEOUT_MS=900000
# Health/liveness HTTP endpoint the watcher serves (GET /health, GET /ready) so
# orchestrators can detect a wedged worker. /health returns 503 if the poll loop
# hasn't ticked within WATCHER_HEALTH_STALE_AFTER_MS. All optional — defaults shown.
# WATCHER_HEALTH_PORT=4002          # port for the watcher health server (1-65535)
# WATCHER_HEALTH_HOST=0.0.0.0       # bind address (0.0.0.0 for container health probes)
# WATCHER_HEALTH_STALE_AFTER_MS=120000  # mark /health stale if no loop tick within this window
# Per-request timeout for hosted-API chat calls (openai-compatible / azure).
AGENT_API_TIMEOUT_MS=120000
# Service credential the watcher uses to authenticate to the API. Required when
# AUTH_REQUIRED=true — otherwise every /api/jobs/claim returns 401 and the
# watcher crash-loops. The M2M app must be authorised for the AUTH0_AUDIENCE API
# with the manage:jobs, ask:knowledge, read:knowledge and manage:knowledge
# permissions. The token endpoint and audience are derived from the AUTH0_* vars
# above.
#
#   PREFERRED — client-credentials, fetched and refreshed at runtime so it
#   survives the ~24h Auth0 token lifetime.
WATCHER_API_CLIENT_ID=
WATCHER_API_CLIENT_SECRET=
#   LEGACY — a static pre-minted access token (API_TOKEN). Simpler but EXPIRES;
#   after expiry every claim 401s until it is replaced. Prefer the pair above for
#   any long-running deployment. Used only when the pair is unset.
# API_TOKEN=

# ── OpenAI-compatible chat ───────────────────────────────────────
# A watcher advertises the `openai-compatible` capability only when all three
# are set.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# OpenAI-compatible embeddings (hybrid retrieval; model must be 1536-dim).
# Base URL/key fall back to the chat values above when blank — only set these
# when embeddings live on a different endpoint than chat (e.g. DeepSeek for
# chat, OpenAI for embeddings).
OPENAI_COMPATIBLE_EMBEDDING_BASE_URL=
OPENAI_COMPATIBLE_EMBEDDING_API_KEY=
OPENAI_COMPATIBLE_EMBEDDING_MODEL=

# ── Azure OpenAI (alternative to OpenAI-compatible) ──────────────
# A watcher advertises the `azure-openai` capability when ENDPOINT, API_KEY and
# CHAT_DEPLOYMENT are all set. EMBEDDING_DEPLOYMENT enables Azure embeddings for
# retrieval; API_VERSION has the default shown below.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Git provider credentials ─────────────────────────────────────
# GITHUB_TOKEN (github.com) and AZURE_DEVOPS_PAT (dev.azure.com / *.visualstudio.com)
# authenticate HTTPS clone/fetch/pull/push when set — required to publish branches
# from a container with no ambient git credentials. The token is matched to the
# remote's host and passed via the environment (never the URL or command line). A
# credential-embedded URL or SSH remote bypasses these and is used as-is.
# GIT_PROVIDER is display-only (defaults to "local").
GIT_PROVIDER=local
GITHUB_TOKEN=
# Identity used for commits created by "Publish branch". REQUIRED — publishing
# fails fast if either is unset (no fallback identity is assumed). Set both in any
# environment that publishes branches, including containers without ambient git config.
# A watcher advertises the `github` capability only when GITHUB_TOKEN,
# MAGPIE_GIT_AUTHOR_NAME and MAGPIE_GIT_AUTHOR_EMAIL are all set.
MAGPIE_GIT_AUTHOR_NAME=
MAGPIE_GIT_AUTHOR_EMAIL=
# Publishing a GitHub-hosted proposal also opens a pull request when GITHUB_TOKEN
# is set; other hosts fall back to a branch-only publish. The "Pull request status
# refresh" runs as a scheduled maintenance job (pg-boss cron) that watches open
# PRs and advances proposals when they merge (resolve gaps + re-index) or close.
AZURE_DEVOPS_PAT=

# ── External agent CLIs (codex / claude watcher providers) ───────
# A watcher advertises the `codex` capability when CODEX_CLI_PATH is set and the
# `claude` capability when CLAUDE_CLI_PATH is set; both default to a bare command
# name resolved on PATH. On Windows, point *_CLI_PATH at a directly-spawnable
# executable (e.g. claude.exe) — a .cmd/.ps1 PATH shim fails to spawn.
CODEX_CLI_PATH=codex
CODEX_CLI_ARGS=exec
# Prompt delivery: `arg` passes the prompt as a CLI argument; `stdin` pipes it in.
# Use `stdin` on Windows — retrieval-augmented prompts exceed the ~32 KB command
# line limit and fail with `spawn ENAMETOOLONG` in `arg` mode.
CODEX_CLI_PROMPT_MODE=arg
# Optional model name. When set, `--model <value>` is appended to the CLI args
# (the flag codex and claude share). Leave blank to use the CLI's own default.
CODEX_CLI_MODEL=
CLAUDE_CLI_PATH=claude
CLAUDE_CLI_ARGS=-p
CLAUDE_CLI_PROMPT_MODE=arg
CLAUDE_CLI_MODEL=
# Per-invocation timeout for agent CLI runs.
AGENT_CLI_TIMEOUT_MS=120000
# Grace period a cancelled CLI job is given to exit before it is killed.
CLI_CANCEL_GRACE_MS=5000

# ── Optional tunables (defaults shown; uncomment to override) ────
# LOG_LEVEL=info                  # api/watcher/mcp log verbosity: trace|debug|
#                                 # info|warn|error|fatal (default: info in
#                                 # production, debug otherwise). Structured JSON.
# PORT=4000                       # API listen port (web uses 3000 via next)
# ANSWER_POLL_INTERVAL_MS=1000    # MCP: poll cadence while awaiting an answer
# ANSWER_TIMEOUT_MS=120000        # MCP: give up waiting for an answer after this
# EVAL_TIMEOUT_MS=30000           # scripts/eval-api.ts request timeout
# JOB_RUN_TO_COMPLETION_TIMEOUT_MS=  # override per-job completion deadline
#                                    # (default = the job type's expireInSeconds)

# ── Observability / OpenTelemetry (optional; OFF by default) ─────
# Telemetry turns on only when an OTLP endpoint is set. Export is OTLP, so point
# it at any backend (Grafana/Tempo, Datadog, Honeycomb, Sentry) or an OTel
# Collector. The SDK reads the standard OTEL_* vars directly.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318  # enables telemetry when set
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer xxx  # e.g. backend auth
# OTEL_SERVICE_NAME=                 # overrides the default (api / watcher)
# MAGPIE_TELEMETRY_ENABLED=false     # force-disable even when an endpoint is set
