{
  "name": "@magpie/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=../../.env --import tsx src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include=\"src/**\" --test-coverage-exclude=\"**/*.test.ts\" \"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.9",
    "@hono/zod-validator": "^0.9.0",
    "@magpie/auth": "file:../../packages/auth",
    "@magpie/core": "file:../../packages/core",
    "@magpie/git": "file:../../packages/git",
    "@magpie/jobs": "file:../../packages/jobs",
    "@magpie/logger": "file:../../packages/logger",
    "@magpie/markdown": "file:../../packages/markdown",
    "@magpie/prompts": "file:../../packages/prompts",
    "@magpie/retrieval": "file:../../packages/retrieval",
    "@magpie/telemetry": "file:../../packages/telemetry",
    "@types/pg": "^8.20.0",
    "cron-parser": "^5.6.2",
    "hono": "^4.12.30",
    "pg": "^8.22.0",
    "pg-boss": "^12.26.0",
    "tsx": "^4.23.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "jose": "^6.2.3",
    "typescript": "^6.0.3"
  }
}
