{
  "name": "@magpie/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "dev:http": "tsx src/http.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:http": "node dist/http.js",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@magpie/auth": "file:../../packages/auth",
    "@magpie/logger": "file:../../packages/logger",
    "@modelcontextprotocol/express": "^2.0.0-beta.2",
    "@modelcontextprotocol/node": "^2.0.0-beta.4",
    "@modelcontextprotocol/server": "^2.0.0-beta.3",
    "tsx": "^4.23.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "jose": "^6.2.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  }
}
