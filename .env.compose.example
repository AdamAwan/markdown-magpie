# markdown-magpie — Docker Compose baseline.
# `docker compose up` loads THIS file directly (see x-magpie-env in
# docker-compose.yml), then layers .env.compose on top for secrets/overrides.
# .env.compose is gitignored and must not be committed.
#
# This file intentionally holds ONLY the values that differ for Compose — i.e.
# that deviate from the app's built-in defaults or from local-dev hostnames.
# For the FULL catalogue of supported variables (chat/embedding providers,
# Azure, git credentials, agent CLIs, per-store overrides, tunables), see
# .env.example and copy whatever you need into .env.compose.

# ── Container-internal URLs (Compose service names, not localhost) ─
DATABASE_URL=postgres://postgres:postgres@postgres:5432/markdown_magpie
API_BASE_URL=http://api:4000

# Browser-facing API URL. The web image is built ahead of time, so the client
# bundle's NEXT_PUBLIC_API_BASE_URL is fixed at build time; PUBLIC_API_BASE_URL
# is read at runtime by the server and is the one to set here. Point it at the
# published API origin (e.g. http://localhost:4000) when browsers must reach the
# API on a different host/port; leave blank if it shares the web app's origin.
PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_BASE_URL=

# ── Auth0 (production hostnames; auth FAILS CLOSED) ───────────────
# These override the local-dev defaults from .env.example with the deployed
# hostnames. Auth FAILS CLOSED: it is REQUIRED unless AUTH_REQUIRED is set
# EXACTLY to false, and when required the API refuses to start until AUTH0_AUDIENCE
# (a real identifier, not the .env.example placeholder) and AUTH0_DOMAIN/
# AUTH0_ISSUER_BASE_URL are provided in .env.compose. So either:
#   - production: leave AUTH_REQUIRED unset and set the real AUTH0_* + MCP token
#     values in .env.compose; or
#   - unauthenticated stack: set AUTH_REQUIRED=false explicitly.
# The web app reads these at runtime (no rebuild needed).
AUTH0_REDIRECT_URI=https://magpie.wastedcake.com
MCP_RESOURCE_URL=https://mcp-magpie.wastedcake.com/mcp

# ── Persistence & AI provider ────────────────────────────────────
# Log verbosity for the api/watcher/mcp services: trace|debug|info|warn|error|
# fatal. Defaults to info in production, debug otherwise. Logs are structured
# JSON on stdout (stderr for the stdio MCP), ready for a log aggregator.
# LOG_LEVEL=info
# postgres cascades to every store, including KNOWLEDGE_STORE — which is what
# enables semantic/hybrid retrieval (the image's Postgres ships pgvector).
STORAGE_BACKEND=postgres
# All AI work runs through the pg-boss queue: the watcher service claims and
# completes jobs; the API never runs AI inline. AI_PROVIDER is mandatory and
# must name a real watcher provider (openai-compatible | azure-openai | codex |
# claude). docker-compose.yml requires it via ${AI_PROVIDER:?...}, so set it
# here (or in the shell) along with the matching provider credentials in
# .env.compose — there is no built-in fallback provider.
AI_PROVIDER=openai-compatible
# The watcher only advertises (and therefore claims) a provider's capability
# once its credentials are set. Copy the matching block from .env.example into
# .env.compose, e.g. for the default provider above:
#   OPENAI_COMPATIBLE_BASE_URL=...
#   OPENAI_COMPATIBLE_API_KEY=...
#   OPENAI_COMPATIBLE_MODEL=...
WATCHER_NAME=compose-watcher

# -- Knowledge configuration ------------------------------------------------
# No bundled knowledge base is included. Configure your own local folder or
# git-backed split in .env.compose before indexing/asking.
KNOWLEDGE_SOURCES=[]
KNOWLEDGE_DESTINATIONS=[]
KNOWLEDGE_FLOWS=[]
# Example git-backed split:
# KNOWLEDGE_SOURCES=[{"id":"source","name":"Source Repo","url":"https://github.com/org/source.git","subpath":"src"},{"id":"agent","name":"Agent Knowledge","kind":"agent"}]
# KNOWLEDGE_DESTINATIONS=[{"id":"docs","name":"Docs Repo","url":"https://github.com/org/docs.git","subpath":"docs"}]
# KNOWLEDGE_FLOWS=[{"id":"docs","name":"Docs KB","sourceIds":["source","agent"],"destinationId":"docs"}]
