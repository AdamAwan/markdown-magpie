# Copy this file to .env.compose for Docker Compose showcase deployments.
# Do not commit .env.compose because it may contain API keys.

# Browser-facing URL for the web app.
APP_BASE_URL=http://localhost:3000

# Optional browser-facing API URL used by the Next.js frontend.
# Leave this blank for the default http://current-browser-host:4000 behavior.
PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_BASE_URL=

# Container-internal service URLs. These use Compose service names.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/markdown_magpie
QUEUE_URL=redis://redis:6379
API_BASE_URL=http://api:4000

# Persistent stores for a showcase deployment.
STORAGE_BACKEND=postgres

# Use queue mode when the watcher should complete AI jobs.
AI_EXECUTION_MODE=queue
AI_PROVIDER=mock
WATCHER_NAME=compose-watcher
WATCHER_POLL_INTERVAL_MS=2000
AGENT_API_TIMEOUT_MS=120000

# Default deterministic provider. Good for demos without external model keys.
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock
GIT_PROVIDER=local

# Optional OpenAI-compatible watcher/provider settings.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# Optional Azure OpenAI settings.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Optional Git provider settings.
GITHUB_TOKEN=
AZURE_DEVOPS_ORG_URL=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=

# Optional external agent watcher settings. These only work if the CLI exists
# inside the image or is provided by a custom derived image.
CODEX_CLI_PATH=codex
CODEX_CLI_ARGS=exec
CODEX_CLI_PROMPT_MODE=arg
CLAUDE_CLI_PATH=claude
CLAUDE_CLI_ARGS=-p
CLAUDE_CLI_PROMPT_MODE=arg
AGENT_CLI_TIMEOUT_MS=120000
