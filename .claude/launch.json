{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:web"],
      "port": 3000,
      "autoPort": false,
      "env": {
        "MAGPIE_DEV_API_PROXY": "http://localhost:4000"
      }
    },
    {
      "name": "deck",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8771", "--directory", "presentation"],
      "port": 8771,
      "autoPort": false
    }
  ]
}
